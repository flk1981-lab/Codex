# macOS
.DS_Store

# Codex app and repo-local runtime state
.codex/
**/.codex/

# Python environments and caches
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local env files
.env
.env.*
!.env.example
!.env.sample

# Notebook checkpoints
.ipynb_checkpoints/

# Local outputs and generated reports
reports/**/pending/
reports/**/*.docx
reports/**/*.pdf
reports/**/*.pptx

# Backups and temporary files
*.tmp
*.bak
archive/_docx_edit_tmp/
archive/bdlm_temp/

# Large local installers are not suitable for GitHub sync
archive/_installers/

# Nested project repositories are managed separately
workspaces/*
!workspaces/README.md
